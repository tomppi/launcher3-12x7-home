<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Drawer Widget</string>
    <string name="widget_description">Large app drawer widget with four all-app rows and two favorites rows.</string>

    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowBackground">#202020</item>
        <item name="android:colorAccent">#FFFFFF</item>
        <item name="android:navigationBarColor">#202020</item>
        <item name="android:statusBarColor">#202020</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="LaunchProxyTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorAccent">#FFFFFF</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
